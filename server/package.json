{
    "name": "tiktok-dashboard-backend",
    "version": "1.0.0",
    "description": "Backend server for TikTok Dashboard API integration",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "seed:test-role-users": "tsx scripts/seed-role-test-users.ts",
        "test:ingestion": "node --import tsx --test src/tests/ingestion-queue.test.ts",
        "test": "node --import tsx --test src/tests/rbac-prd-alignment.test.ts src/tests/custom-roles-authorization.test.ts src/tests/custom-roles-migration.test.ts src/tests/ingestion-queue.test.ts src/tests/tenant-prd-alignment.test.ts src/tests/http-health.integration.test.ts src/tests/agency-task-coordinator-scope.test.ts src/tests/agency-tasks-prd-compliance.test.ts",
        "test:tasks-http": "RUN_TASK_HTTP_E2E=1 node --import tsx --test src/tests/agency-tasks-http.integration.test.ts"
    },
    "keywords": [
        "tiktok",
        "api",
        "express",
        "backend"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@sentry/node": "^10.48.0",
        "@supabase/supabase-js": "^2.57.4",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.5",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.16.0",
        "axios": "^1.6.2",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "multer": "^2.1.1",
        "node-cron": "^3.0.3",
        "pdfkit": "^0.17.2",
        "pg": "^8.16.3",
        "typescript": "^5.3.3",
        "undici": "^7.23.0"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/multer": "^2.1.0",
        "@types/pdfkit": "^0.17.3",
        "tsx": "^4.7.0",
        "supertest": "^7.0.0",
        "@types/supertest": "^6.0.2"
    }
}
