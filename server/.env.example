# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development   # set to 'production' in Vercel / hosting env

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

FRONTEND_URL=http://localhost:5173
# Comma-separated additional allowed CORS origins (e.g. staging URL)
FRONTEND_URLS=

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret sent by Vercel Cron in the Authorization: Bearer <secret> header.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# DSN from https://sentry.io — leave blank to disable error tracking in dev
SENTRY_DSN=

# ── Dead-letter Alerting ──────────────────────────────────────────────────────
# Optional: POST this webhook when dead-letter job count exceeds threshold (Slack, Discord, etc.)
DEAD_LETTER_WEBHOOK_URL=
# Threshold count before alerting fires (default: 1)
DEAD_LETTER_ALERT_THRESHOLD=1

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com
RESEND_API_KEY=
# Must be a domain you verified in Resend (e.g. onboarding@resend.dev for testing, or mail@mamba.app)
INVITE_FROM_EMAIL=
REPORTS_FROM_EMAIL=
