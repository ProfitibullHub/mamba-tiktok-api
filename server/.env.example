# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development   # set to 'production' in Vercel / hosting env

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

FRONTEND_URL=http://localhost:5173
# Comma-separated additional allowed CORS origins (e.g. staging URL)
FRONTEND_URLS=

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret sent by Vercel Cron in the Authorization: Bearer <secret> header.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# DSN from https://sentry.io — leave blank to disable error tracking in dev
SENTRY_DSN=

# ── Dead-letter Alerting ──────────────────────────────────────────────────────
# Optional: POST this webhook when dead-letter job count exceeds threshold (Slack, Discord, etc.)
DEAD_LETTER_WEBHOOK_URL=
# Threshold count before alerting fires (default: 1)
DEAD_LETTER_ALERT_THRESHOLD=1

# ── Email (GoHighLevel / LeadConnector API v2) ────────────────────────────────
# Private Integration Token (Sub-Account) — https://marketplace.gohighlevel.com/docs/Authorization/PrivateIntegrationsToken
GOHIGHLEVEL_PIT=
# Sub-account location id (used for contacts upsert + conversations)
GOHIGHLEVEL_LOCATION_ID=
# If 1/true: skip retry of GET …/messages without locationId when list returns 0 rows (default: retry once).
GHL_MESSAGES_REQUIRE_LOCATION_ID=
# Optional: outbound From address (must align with ProfitBull/HL mailbox settings)
INVITE_FROM_EMAIL=
REPORTS_FROM_EMAIL=
# Optional: display name when From is a bare address (otherwise callers pass fromDisplayName)
REPORTS_FROM_DISPLAY_NAME=

# Optional: fallback when parent agency has no tenant_branding.email_sender_address
MESSAGING_AGENCY_NOTIFY_EMAIL=
# Inbound (optional): GHL InboundMessage webhook — only if you use Marketplace app webhooks.
# PIT + location polling does NOT require this. See server ghl-messages-sync.service.ts
MESSAGING_GHL_WEBHOOK_SECRET=
# Allow platform super admin to create threads + send (PRD is agency/seller; default off)
MESSAGING_ALLOW_PLATFORM_SUPER_ADMIN_SEND=false

# New-message digest to agency inbox; set to 0|false|no to disable (replies still stored)
MESSAGING_NOTIFY_EMAIL=

# ── Bug reports (GoHighLevel Conversations) ─────────────────────────────────────
# Uses GOHIGHLEVEL_PIT + GOHIGHLEVEL_LOCATION_ID above. Sends two emails when inbox ≠ reporter:
#   (1) To reporter — full body + screenshot attachments; (2) To this inbox — same body + same attachments (re-uploaded per GHL contact).
# If inbox equals the reporter email, only one message is sent. Uses agency branding From when configured (dashboard parity).
GOHIGHLEVEL_BUG_REPORT_TO_EMAIL=
# Optional screenshots: up to 2 images × 1 MB each (JSON body limit); PNG/JPEG/GIF/WebP only.
# Optional: expose GET /api/support/bug-reports + cached status refresh (requires DB migration applied)
SUPPORT_TICKET_STATUS_ENABLED=false
# Seconds between vendor API refreshes per row when listing (default 600)
SUPPORT_TICKET_STATUS_TTL_SECONDS=600
# Optional build label appended to ticket metadata (else Vercel commit SHA / nothing)
APP_BUILD_VERSION=
