{
    "version": 2,
    "builds": [
        {
            "src": "src/index.ts",
            "use": "@vercel/node",
            "config": {
                "maxDuration": 300
            }
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/src/index.ts"
        }
    ],
    "crons": [
        {
            "path": "/api/tiktok-shop/sync/cron-settlements",
            "schedule": "0 7 * * *"
        },
        {
            "path": "/api/reports/cron-dashboard-digests",
            "schedule": "45 8 * * *"
        }
    ]
}